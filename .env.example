# Con Lovable Cloud attivo il file .env è gestito da Lovable e contiene già
# VITE_SUPABASE_URL e VITE_SUPABASE_PUBLISHABLE_KEY: non serve fare nulla.
# Per un setup manuale, copia questo file in .env con i valori del progetto
# (Dashboard Supabase → Project Settings → API). Mai committare la service key.
VITE_SUPABASE_URL=https://TUO-PROGETTO.supabase.co
VITE_SUPABASE_ANON_KEY=la-tua-anon-key
